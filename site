    <script>
      document.querySelectorAll("[data-carousel='team']").forEach((carousel) => {
        const track = carousel.querySelector(".team-grid");
        const previous = carousel.querySelector("[data-carousel-prev]");
        const next = carousel.querySelector("[data-carousel-next]");

        const scrollTeam = (direction) => {
          const card = track.querySelector(".member");
          const gap = 22;
          const distance = card ? card.getBoundingClientRect().width + gap : track.clientWidth;
          track.scrollBy({ left: direction * distance, behavior: "smooth" });
        };

        previous.addEventListener("click", () => scrollTeam(-1));
        next.addEventListener("click", () => scrollTeam(1));
      });
    </script>
